# Database
DATABASE_URL=postgresql+asyncpg://cineiq:cineiq_password@localhost:5432/cineiq

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

# ML Models
SVD_MODEL_PATH=./backend/app/ml/models/svd_v1.pkl
NCF_MODEL_PATH=./backend/app/ml/models/ncf_v1.pt

# S3/MinIO
S3_BUCKET=cineiq-posters
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Ensemble Weights
ENSEMBLE_WEIGHT_SVD=0.40
ENSEMBLE_WEIGHT_NCF=0.30
ENSEMBLE_WEIGHT_CONTENT=0.20
ENSEMBLE_WEIGHT_SENTIMENT=0.10

# Application
APP_NAME=CINEIQ
DEBUG=true
