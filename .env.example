# Database Configuration
DATABASE_URL=postgresql+asyncpg://cineiq:cineiq_password@localhost:5432/cineiq

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Clerk Authentication
CLERK_SECRET_KEY=REPLACE_WITH_YOUR_KEY
CLERK_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_KEY

# TMDB API
TMDB_API_KEY=REPLACE_WITH_YOUR_KEY

# Groq API
GROQ_API_KEY=REPLACE_WITH_YOUR_KEY

# ML Model Paths
SVD_MODEL_PATH=./backend/app/ml/models/svd_v1.pkl
NCF_MODEL_PATH=./backend/app/ml/models/ncf_v1.pt

# S3/MinIO Configuration (local development)
S3_BUCKET=cineiq-posters
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Ensemble Weights (optional overrides)
ENSEMBLE_WEIGHT_SVD=0.40
ENSEMBLE_WEIGHT_NCF=0.30
ENSEMBLE_WEIGHT_CONTENT=0.20
ENSEMBLE_WEIGHT_SENTIMENT=0.10

# Frontend Environment Variables
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
